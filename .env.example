# VoltIQ Backend Environment Configurations

# Anthropic Claude API Key for the AI Copilot and risk reasoning
ANTHROPIC_API_KEY=sk-ant-your-key-here

# SQLite Database connection URL
DATABASE_URL=sqlite:///./voltiq.db

# CORS configurations (comma-separated list of domains)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Backend host and port (optional, defaults are 0.0.0.0:8000)
HOST=0.0.0.0
PORT=8000
